# Wajib diganti di production
AUTH_SECRET=ganti-dengan-secret-panjang-acak

# Akun admin awal (dibuat otomatis saat container start)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin Pemilu

# Google Sheets (opsional — bisa diisi nanti lewat dashboard Admin → Sinkronisasi)
SPREADSHEET_ID=
SHEET_NAME=Form Responses 1
# JSON service account dalam satu baris
GOOGLE_SERVICE_ACCOUNT=

# Interval sync otomatis (ms), default 2 menit
SYNC_INTERVAL_MS=120000
